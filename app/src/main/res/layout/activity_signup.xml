<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#31354C"
    tools:context=".AccountDetails.SignupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_image"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginTop="50dp"
            android:src="@drawable/profile"
            app:civ_border_width="2dp"
            app:civ_border_color="#009688" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Tap to upload image"
            android:textColor="#fff"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/app_name"
            android:textAlignment="center"
            android:textColor="#009688"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:background="@drawable/design_edittext"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="10dp"
            android:hint="Enter username"
            android:textColor="#000"
            android:id="@+id/username"
            android:inputType="text"
            android:textIsSelectable="true"
            android:focusable="true"
            android:textAlignment="viewStart"
            android:paddingStart="20sp"
            android:focusableInTouchMode="true"
            tools:ignore="HardcodedText,RtlSymmetry"></EditText>
        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/design_edittext"
            android:layout_margin="10dp"
            android:hint="Enter email"
            android:textAlignment="viewStart"
            android:paddingStart="20sp"
            android:textColor="#000"
            android:id="@+id/email"
            android:textIsSelectable="true"
            android:inputType="textEmailAddress"
            android:focusable="true"
            android:focusableInTouchMode="true"
            tools:ignore="HardcodedText,RtlSymmetry"></EditText>
        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/design_edittext"
            android:layout_margin="10dp"
            android:textAlignment="viewStart"
            android:paddingStart="20sp"
            android:hint="Enter password"
            android:textColor="#000"
            android:id="@+id/password"
            android:inputType="textVisiblePassword"
            app:passwordToggleEnabled="true"
            android:textIsSelectable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            tools:ignore="HardcodedText,RtlSymmetry"></EditText>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:textSize="18sp"
            android:text="Sign UP"
            android:textColor="#fff"
            android:id="@+id/signup"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:background="#327AB3"
            android:textStyle="bold"
            tools:ignore="HardcodedText"></Button>

        <TextView
            android:id="@+id/loginLink"
            android:onClick="login"
            android:layout_width="match_parent"
            android:text="Already have account?"
            android:textAlignment="center"
            android:textSize="15sp"
            android:textColor="#fff"
            android:layout_margin="20sp"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            tools:ignore="HardcodedText,UsingOnClickInXml"></TextView>


    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>